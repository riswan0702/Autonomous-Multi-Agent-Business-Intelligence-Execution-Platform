# =============================================
# Multi-Agent BI Platform — Environment Config
# =============================================

# REQUIRED: Get free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# App
ENVIRONMENT=development

# Cost protection (stops agents if token budget is exceeded)
MAX_TOKENS_PER_RUN=80000

# Security (max agent runs per workflow to prevent infinite loops)
MAX_AGENT_LOOPS=10

# Memory (ChromaDB vector store)
ENABLE_MEMORY=true
MEMORY_PATH=./memory_store

# Logging
LOG_LEVEL=INFO
